<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Email Verification OTP</title>
  </head>
  <body style="margin:0;padding:0;background:#f5f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f5f7fb;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="max-width:600px;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e5e7eb;">
            <tr>
              <td style="background:#b91c1c;padding:18px 24px;color:#ffffff;font-size:20px;font-weight:700;">
                Saviour
              </td>
            </tr>
            <tr>
              <td style="padding:28px 24px 10px 24px;font-size:18px;font-weight:700;">
                Verify your email address
              </td>
            </tr>
            <tr>
              <td style="padding:0 24px 12px 24px;line-height:1.6;font-size:14px;">
                Hi <%= name || "there" %>,<br/>
                Use the OTP below to verify your email address and activate your Saviour account.
              </td>
            </tr>
            <tr>
              <td align="center" style="padding:10px 24px 18px 24px;">
                <div style="display:inline-block;background:#111827;color:#ffffff;font-size:30px;letter-spacing:8px;padding:12px 18px;border-radius:8px;font-weight:700;">
                  <%= otp %>
                </div>
              </td>
            </tr>
            <tr>
              <td style="padding:0 24px 18px 24px;line-height:1.6;font-size:14px;">
                This OTP expires in <strong><%= expiresIn || "10 minutes" %></strong>. Do not share this code with anyone.
              </td>
            </tr>
            <tr>
              <td style="padding:0 24px 28px 24px;line-height:1.6;font-size:12px;color:#6b7280;">
                If you did not request this, you can safely ignore this email.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
