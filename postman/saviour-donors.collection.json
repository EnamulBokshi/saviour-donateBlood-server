{
  "info": {
    "_postman_id": "f1a1a9f1-1c9d-4f08-8e8b-b3d7e1b2a101",
    "name": "Saviour Server - Donor APIs",
    "description": "Donor collection for the Saviour backend. Base route: /api/v1/donors. Use the shared environment for baseUrl, accessToken, and donorId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "donorId", "value": "" },
    { "key": "searchTerm", "value": "Dhaka" },
    { "key": "page", "value": "1" },
    { "key": "limit", "value": "10" },
    { "key": "sortBy", "value": "createdAt" },
    { "key": "sortOrder", "value": "desc" },
    { "key": "bloodGroup", "value": "O_POSITIVE" },
    { "key": "isAvailable", "value": "true" },
    { "key": "lastDonationDate", "value": "2026-01-15T00:00:00.000Z" }
  ],
  "item": [
    {
      "name": "Donor - List",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Store first donor id when available', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  const firstDonor = responseBodyJson && responseBodyJson.data && responseBodyJson.data[0];",
              "  if (firstDonor && firstDonor.id) {",
              "    pm.collectionVariables.set('donorId', firstDonor.id);",
              "    pm.environment.set('donorId', firstDonor.id);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/donors?searchTerm={{searchTerm}}&page={{page}}&limit={{limit}}&sortBy={{sortBy}}&sortOrder={{sortOrder}}&bloodGroup={{bloodGroup}}&isAvailable={{isAvailable}}&lastDonationDate={{lastDonationDate}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "donors"],
          "query": [
            { "key": "searchTerm", "value": "{{searchTerm}}" },
            { "key": "page", "value": "{{page}}" },
            { "key": "limit", "value": "{{limit}}" },
            { "key": "sortBy", "value": "{{sortBy}}" },
            { "key": "sortOrder", "value": "{{sortOrder}}" },
            { "key": "bloodGroup", "value": "{{bloodGroup}}" },
            { "key": "isAvailable", "value": "{{isAvailable}}" },
            { "key": "lastDonationDate", "value": "{{lastDonationDate}}" }
          ]
        }
      }
    },
    {
      "name": "Donor - Get By ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Store donor id from response', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  if (responseBodyJson && responseBodyJson.data && responseBodyJson.data.id) {",
              "    pm.collectionVariables.set('donorId', responseBodyJson.data.id);",
              "    pm.environment.set('donorId', responseBodyJson.data.id);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/donors/{{donorId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "donors", "{{donorId}}"]
        }
      }
    },
    {
      "name": "Donor - Update",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Updated Donor Name\",\n  \"age\": 29,\n  \"bloodGroup\": \"O_POSITIVE\",\n  \"contactNumber\": \"+8801711111111\",\n  \"address\": \"Dhaka, Bangladesh\",\n  \"lastDonationDate\": \"2026-01-15T00:00:00.000Z\",\n  \"isAvailable\": true,\n  \"totalDonations\": 4\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/donors/{{donorId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "donors", "{{donorId}}"]
        }
      }
    },
    {
      "name": "Donor - Delete",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/donors/{{donorId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "donors", "{{donorId}}"]
        }
      }
    }
  ]
}