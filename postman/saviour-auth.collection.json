    {
      "name": "Auth - Refresh Token (POST, Flutter-friendly)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Update stored tokens', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  if (responseBodyJson && responseBodyJson.data) {",
              "    if (responseBodyJson.data.accessToken) {",
              "      pm.collectionVariables.set('accessToken', responseBodyJson.data.accessToken);",
              "    }",
              "    if (responseBodyJson.data.refreshToken) {",
              "      pm.collectionVariables.set('refreshToken', responseBodyJson.data.refreshToken);",
              "    }",
              "    if (responseBodyJson.data.sessionToken) {",
              "      pm.collectionVariables.set('sessionToken', responseBodyJson.data.sessionToken);",
              "    }",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"sessionToken\": \"{{sessionToken}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/refresh-token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "refresh-token"
          ]
        }
      }
