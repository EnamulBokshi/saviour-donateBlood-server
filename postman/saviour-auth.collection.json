    {
      "name": "Auth - Sign In (Email)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 or 201', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test('Store access/refresh/session tokens', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  if (responseBodyJson && responseBodyJson.data) {",
              "    if (responseBodyJson.data.accessToken) {",
              "      pm.collectionVariables.set('accessToken', responseBodyJson.data.accessToken);",
              "    }",
              "    if (responseBodyJson.data.refreshToken) {",
              "      pm.collectionVariables.set('refreshToken', responseBodyJson.data.refreshToken);",
              "    }",
              "    if (responseBodyJson.data.token) {",
              "      pm.collectionVariables.set('sessionToken', responseBodyJson.data.token);",
              "    }",
              "    if (responseBodyJson.data.sessionToken) {",
              "      pm.collectionVariables.set('sessionToken', responseBodyJson.data.sessionToken);",
              "    }",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/sign-in/email",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "sign-in",
            "email"
          ]
        }
      }
    },
