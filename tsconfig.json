{
  "compilerOptions": {
    "module": "esnext",                                
    "target": "es2023",
    "outDir": "./dist",  
    "moduleResolution": "bundler", 
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["src"],
  "exclude": ["node_modules","build", "dist"]
}